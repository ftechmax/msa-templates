{
  "$schema": "http://json.schemastore.org/template",
  "author": "ftechmax",
  "classifications": ["Common", "Worker", "MSA"],
  "tags": {
    "language": "C#",
    "type": "solution"
  },
  "name": ".NET worker microservice",
  "description": "A worker microservice solution",
  "identity": "Dotnet.MSA.Worker",
  "shortName": "msa-worker",
  "defaultName": "Worker1",
  "sourceName": "ApplicationName",
  "preferNameDirectory": true,
  "primaryOutputs": [{ "path": "ApplicationName.sln" }],
  "symbols": {
    "lowerCaseName": {
      "type": "generated",
      "generator": "casing",
      "parameters": {
        "source": "name",
        "toLower": true
      }
    },
    "snakeCaseName": {
      "type": "generated",
      "generator": "regex",
      "datatype": "string",
      "parameters": {
        "source": "lowerCaseName",
        "steps": [
          {
            "regex": "\\.",
            "replacement": "_"
          }
        ]
      },
      "replaces": "applicationname_snake"
    }
  }
}
